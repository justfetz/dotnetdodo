@page

@model dotnetdodo.Models.OrderFormModel

<form method="post">
    <div class="form-group">
        <label for="widths">Widths (comma separated)</label>
        <input id="widths" name="widths" type="text" class="form-control" required />
    </div>
    <div class="form-group">
        <label for="demands">Demands (comma separated)</label>
        <input id="demands" name="demands" type="text" class="form-control" required />
    </div>
    <div class="form-group">
        <label for="stock">Stock Item Width</label>
        <input id="stock" name="stock" type="number" class="form-control" required />
    </div>
    <button type="submit" class="btn btn-primary">Submit</button>
</form>
